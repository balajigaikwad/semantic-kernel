{
  "version": "1.0.0",
  "author": "balaji",
  "description": "A plugin that provides jokes.",
  "execution_settings": {
    "default": {
      "max_tokens": 150,
      "temperature": 0.8,
      "top_p": 0.0,
      "frequency_penalty": 0.0,
      "presence_penalty": 0.0
    }
  },
  "input_variables": [
    {
      "name": "input",
      "description": "The category of the joke (e.g., 'general', 'kid', 'knock-knock').",
      "default": ""
    },
    {
      "name": "style",
      "description": "Give a hint about the desired joke style",
      "default": ""
    }
  ],
  "exclude": [
    "**/bin",
    "**/bower_components",
    "**/jspm_packages",
    "**/node_modules",
    "**/obj",
    "**/platforms"
  ]
}